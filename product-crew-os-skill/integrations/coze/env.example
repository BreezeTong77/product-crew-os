# Copy this file to .env and replace every placeholder before deployment.
PCO_RUNTIME_TOKEN=replace_with_a_long_random_secret
PCO_LANGGRAPH_DELEGATE_SECRET=replace_with_a_different_long_random_secret
PCO_SKILL_RECEIPT_SECRET=replace_with_a_third_long_random_secret
PCO_DELEGATE_SIGNER_TOKEN=replace_with_a_fourth_long_random_secret
# A reachable Ollama endpoint, not the Docker container's own localhost.
PCO_OLLAMA_URL=http://host.docker.internal:11434
PCO_SKILL_MODEL=qwen2.5:3b
PCO_EMBEDDING_PROVIDER=local_open_source_bge_small_zh
PCO_BGE_MODEL=BAAI/bge-small-zh-v1.5
# Private file copied from sub-bot-bindings.example.yaml with real Coze Bot IDs.
PCO_SUBAGENT_BINDINGS_PATH=/data/sub-bot-bindings.private.yaml
# Runtime reaches this internal address. Coze needs the signer exposed separately over HTTPS.
PCO_DELEGATE_SIGNER_URL=http://product-crew-os-delegate-signer:8788
