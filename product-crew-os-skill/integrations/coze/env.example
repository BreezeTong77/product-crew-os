# Copy this file to .env and replace every placeholder before deployment.
PCO_RUNTIME_TOKEN=replace_with_a_long_random_secret
PCO_LANGGRAPH_DELEGATE_SECRET=replace_with_a_different_long_random_secret
PCO_SKILL_RECEIPT_SECRET=replace_with_a_third_long_random_secret
# A reachable Ollama endpoint, not the Docker container's own localhost.
PCO_OLLAMA_URL=http://host.docker.internal:11434
PCO_SKILL_MODEL=qwen2.5:3b
